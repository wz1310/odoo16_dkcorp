<record model="ir.ui.view" id="wz_inher_ptemplate">
        <field name="name">Inherit Prod Form MIS</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
            <page string="Upload Image" name="image_upload">      
                <field name="multi_upload_images" widget="multi_image">
                <tree editable="bottom">
                    <field name="image_1920" widget="image" options="{'size': [150, 150]}"/>
                    <field name="name" required="0"/><button name="action_download_image" 
                            type="object" 
                            icon="fa-download" 
                            title="Download Gambar"
                            aria-label="Download"/>
                </tree>
            </field>
            </page>
            </xpath>
        </field>
    </record>

</odoo>